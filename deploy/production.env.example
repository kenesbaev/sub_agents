# Copy this file to .env.production, replace every REPLACE_* value, and keep
# that file outside version control. All public URLs must use one HTTPS origin.
COMPOSE_PROJECT_NAME=teamora-production
PRODUCTION_ENV_FILE=.env.production
IMAGE_TAG=2026.07.16-1
BACKEND_IMAGE=teamora-backend
AGENT_IMAGE=teamora-agent
FRONTEND_IMAGE=teamora-frontend

PUBLIC_ORIGIN=https://app.example.com
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080
TRUSTED_HOSTS=app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

APP_ENV=production
COOKIE_SECURE=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440
LOCAL_PASSWORD_AUTH_ENABLED=false
JWT_SECRET=REPLACE_WITH_64_RANDOM_HEX_CHARACTERS_JWT_SECRET
INTEGRATION_ENCRYPTION_SECRET=REPLACE_WITH_DIFFERENT_64_RANDOM_HEX_CHARACTERS
AGENT_INTERNAL_TOKEN=REPLACE_WITH_THIRD_64_RANDOM_HEX_CHARACTERS

POSTGRES_USER=teamora
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=teamora
DATABASE_URL=postgresql+psycopg://teamora:REPLACE_WITH_URL_SAFE_DATABASE_PASSWORD@postgres:5432/teamora
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=15
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_AUTO_CREATE_SCHEMA=false
DATABASE_STARTUP_BACKFILL=false

# AI gateway limits. The local Codex CLI fallback is intentionally disabled in
# production; use a provider API key with an account-level spend limit.
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_API_KEY
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_TIMEOUT_SECONDS=45
CODEX_TIMEOUT_SECONDS=120
AGENT_CODEX_FALLBACK_ENABLED=false
AGENT_REQUIRE_AUTH=true
AGENT_VALIDATE_USER_DB=true
AGENT_AUTH_COOKIE=rebly_session
AGENT_ALLOWED_ORIGINS=https://app.example.com
AGENT_MAX_REQUEST_BYTES=33554432
AGENT_MAX_MESSAGE_CHARS=20000
AGENT_MAX_CONCURRENT_REQUESTS=8
AGENT_REQUEST_QUEUE_TIMEOUT_SECONDS=0.25
AGENT_RATE_LIMIT_PER_MINUTE=30
AGENT_TEAM_RATE_COST=8
AGENT_PROVIDER_MAX_CONCURRENCY=8
AGENT_PROVIDER_MAX_CONCURRENCY_PER_ACCOUNT=4
AGENT_PROVIDER_QUEUE_TIMEOUT_SECONDS=1
AGENT_RUN_TIMEOUT_SECONDS=150
PENDING_TEAM_RUN_TTL_SECONDS=900
PENDING_TEAM_RUN_MAX_ENTRIES=1000
PENDING_TEAM_RUN_MAX_PER_ACCOUNT=20
OPENROUTER_CIRCUIT_FAILURE_THRESHOLD=3
OPENROUTER_CIRCUIT_COOLDOWN_SECONDS=30
OPENROUTER_WEB_MAX_RESULTS=5
OPENROUTER_WEB_MAX_TOTAL_RESULTS=10
AGENT_SERVER_LOG_LEVEL=INFO
KALIYA_LINK_FETCH_ENABLED=false
KALIYA_VIDEO_LINK_DOWNLOAD_ENABLED=false
TELEGRAM_AUTO_PUBLISH=false

# Required executable: upload all four backup artifacts to encrypted off-site
# storage and exit non-zero unless the remote copy is durably confirmed.
BACKUP_UPLOAD_COMMAND=/usr/local/bin/teamora-upload-backup
REQUIRE_OFFSITE_UPLOAD=1
BACKUP_LOCAL_RETENTION_COUNT=7
BACKUP_MIN_FREE_MB=10240

# YouTube Growth snapshots run only in the dedicated youtube-worker service.
YOUTUBE_API_KEY=
YOUTUBE_SNAPSHOT_WORKER_ENABLED=true
YOUTUBE_SNAPSHOT_WORKER_RUN_IN_API=false
YOUTUBE_SNAPSHOT_WORKER_POLL_SECONDS=60
YOUTUBE_SNAPSHOT_WORKER_BATCH_SIZE=10
YOUTUBE_SNAPSHOT_WORKER_STALE_SECONDS=3600
YOUTUBE_HTTP_TIMEOUT_SECONDS=20
YOUTUBE_MAX_RETRIES=2
YOUTUBE_RETRY_BASE_SECONDS=0.25
YOUTUBE_CACHE_TTL_SECONDS=900
YOUTUBE_MAX_PAGES=5
YOUTUBE_LLM_API_URL=
YOUTUBE_LLM_API_KEY=
YOUTUBE_LLM_MODEL=
YOUTUBE_UPLOAD_ENABLED=false

# Scheduled delivery is deliberately single-item until dispatch-state metrics
# and stronger crash reconciliation are available.
SCHEDULED_POST_WORKER_ENABLED=true
SCHEDULED_POST_WORKER_POLL_SECONDS=5
SCHEDULED_POST_WORKER_BATCH_SIZE=1
SCHEDULED_POST_WORKER_MAX_ATTEMPTS=3
SCHEDULED_POST_WORKER_RETRY_BASE_SECONDS=30
SCHEDULED_POST_WORKER_RETRY_MAX_SECONDS=300
SCHEDULED_POST_WORKER_CLAIM_STALE_SECONDS=300

# OAuth credentials are backend-admin settings. Leave an unused provider blank.
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://app.example.com/api/auth/google/callback
GOOGLE_CONNECTED_REDIRECT_URI=https://app.example.com/api/connected-apps/google/callback
GOOGLE_LOGIN_WORKSPACE_SCOPES=false
GOOGLE_LOGIN_YOUTUBE_SCOPES=false

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://app.example.com/api/connected-apps/meta/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://app.example.com/api/connected-apps/linkedin/callback
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_REDIRECT_URI=https://app.example.com/api/connected-apps/shopify/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://app.example.com/api/connected-apps/tiktok/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://app.example.com/api/connected-apps/x/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://app.example.com/api/connected-apps/discord/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://app.example.com/api/connected-apps/slack/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://app.example.com/api/connected-apps/notion/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://app.example.com/api/connected-apps/github/callback
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=https://app.example.com/api/connected-apps/dropbox/callback
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=https://app.example.com/api/connected-apps/onedrive/callback
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=
STRIPE_REDIRECT_URI=https://app.example.com/api/connected-apps/stripe/callback
