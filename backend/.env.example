APP_ENV=development
DATABASE_URL=postgresql+psycopg://rebly:rebly@localhost:5432/rebly_ai
# Production: generate two different random values with at least 32 characters.
JWT_SECRET=replace-with-a-unique-random-secret-at-least-32-characters
INTEGRATION_ENCRYPTION_SECRET=replace-with-a-different-random-secret-at-least-32-characters
ACCESS_TOKEN_MINUTES=1440
LOCAL_PASSWORD_AUTH_ENABLED=true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_CONNECT_TIMEOUT_SECONDS=10
# Local convenience only. Set both false in staging/production; schema/data
# changes there belong to the one-shot `alembic upgrade head` deployment job.
DATABASE_AUTO_CREATE_SCHEMA=true
DATABASE_STARTUP_BACKFILL=true
# Dedicated scheduled-post publisher. Run exactly through the worker command
# documented below; API replicas never execute this loop.
SCHEDULED_POST_WORKER_ENABLED=false
SCHEDULED_POST_WORKER_POLL_SECONDS=5
SCHEDULED_POST_WORKER_BATCH_SIZE=1
SCHEDULED_POST_WORKER_MAX_ATTEMPTS=3
SCHEDULED_POST_WORKER_RETRY_BASE_SECONDS=30
SCHEDULED_POST_WORKER_RETRY_MAX_SECONDS=300
# Must exceed the longest provider request timeout. Stale claims are never
# auto-retried because the provider may already have accepted the post.
SCHEDULED_POST_WORKER_CLAIM_STALE_SECONDS=300
FRONTEND_URL=http://127.0.0.1:3000
BACKEND_URL=http://127.0.0.1:8000
# Comma-separated exact origins; never use * with credentialed requests.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000
# Comma-separated hostnames accepted by TrustedHostMiddleware.
TRUSTED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false
# Connected Apps OAuth credentials are configured by Rebly AI administrators only.
# End users never enter client IDs, secrets, redirect URIs, OAuth URLs, or scopes.
# Provider endpoint defaults are built into the backend; override with
# PROVIDER_AUTH_URI, PROVIDER_TOKEN_URI, or PROVIDER_USERINFO_URI only when needed.
# Every callback must exactly match the URI registered in that provider's developer portal.
# TikTok and LinkedIn require a publicly reachable HTTPS callback. Use an HTTPS
# tunnel for local testing, then set the production BACKEND_URL and callback URLs before launch.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
GOOGLE_CONNECTED_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/google/callback
GOOGLE_LOGIN_WORKSPACE_SCOPES=false
GOOGLE_LOGIN_YOUTUBE_SCOPES=false
# Optional backend-owned key for public YouTube Data API research. Private
# channel analytics still requires the user's existing Connected Apps OAuth.
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_DATA_API_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_ANALYTICS_API_BASE_URL=https://youtubeanalytics.googleapis.com/v2
YOUTUBE_HTTP_TIMEOUT_SECONDS=20
YOUTUBE_MAX_RETRIES=2
YOUTUBE_RETRY_BASE_SECONDS=0.25
YOUTUBE_CACHE_TTL_SECONDS=900
YOUTUBE_MAX_PAGES=5
# Run snapshots in a dedicated process:
#   python -m app.youtube_growth.worker_main
# Keep RUN_IN_API=false in production so API replicas do not each start a worker.
YOUTUBE_SNAPSHOT_WORKER_ENABLED=false
YOUTUBE_SNAPSHOT_WORKER_RUN_IN_API=false
YOUTUBE_SNAPSHOT_WORKER_POLL_SECONDS=60
YOUTUBE_SNAPSHOT_WORKER_BATCH_SIZE=10
YOUTUBE_SNAPSHOT_WORKER_STALE_SECONDS=3600
# Optional OpenAI-compatible JSON model endpoint used for validated content
# plans. If any value is absent, content-plan generation returns a clear 503.
YOUTUBE_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
YOUTUBE_LLM_API_KEY=your-model-api-key
YOUTUBE_LLM_MODEL=your-json-capable-model
OPENROUTER_API_KEY=your-openrouter-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_TARGET_CHAT_ID=your-channel-chat-id
TELEGRAM_AUTO_PUBLISH=false
TELEGRAM_GROUP_CHAT_ID=your-public-group-or-supergroup
TELEGRAM_AGENT_API_URL=http://127.0.0.1:4173/api/agents/chat
TELEGRAM_TEAM_MESSAGE_DELAY_SECONDS=10
TELEGRAM_ATLAS_BOT_TOKEN=your-atlas-bot-token
TELEGRAM_AVA_BOT_TOKEN=your-ava-bot-token
TELEGRAM_SCOUT_BOT_TOKEN=your-scout-bot-token
TELEGRAM_DEX_BOT_TOKEN=your-dex-bot-token
TELEGRAM_ECHO_BOT_TOKEN=your-echo-bot-token
META_GRAPH_API_VERSION=v23.0
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_OAUTH_URI=https://www.facebook.com/v23.0/dialog/oauth
META_TOKEN_URI=https://graph.facebook.com/v23.0/oauth/access_token
META_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/meta/callback
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_SCOPES=openid,profile,email,w_member_social
LINKEDIN_REDIRECT_URI=https://api.example.com/api/connected-apps/linkedin/callback

SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
# Optional default .myshopify.com store. Teamora otherwise asks the merchant only
# for their store domain when they click Connect; Client ID and secret stay server-side.
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-07
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_inventory,write_inventory,read_discounts,write_discounts,read_analytics
SHOPIFY_REDIRECT_URI=https://api.example.com/api/connected-apps/shopify/callback

TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_SCOPES=user.info.basic,video.list
TIKTOK_REDIRECT_URI=https://api.example.com/api/connected-apps/tiktok/callback

X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_SCOPES=users.read,tweet.read,tweet.write,offline.access
X_REDIRECT_URI=https://api.example.com/api/connected-apps/x/callback

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_SCOPES=identify,email,guilds
DISCORD_REDIRECT_URI=https://api.example.com/api/connected-apps/discord/callback

SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/slack/callback

NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/notion/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/github/callback

DROPBOX_CLIENT_ID=your-dropbox-client-id
DROPBOX_CLIENT_SECRET=your-dropbox-client-secret
DROPBOX_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/dropbox/callback

ONEDRIVE_CLIENT_ID=your-microsoft-client-id
ONEDRIVE_CLIENT_SECRET=your-microsoft-client-secret
ONEDRIVE_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/onedrive/callback

STRIPE_CLIENT_ID=your-stripe-connect-client-id
STRIPE_CLIENT_SECRET=your-stripe-secret-key
STRIPE_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/stripe/callback
