DATABASE_URL=postgresql+psycopg://rebly:rebly@localhost:5432/rebly_ai
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://127.0.0.1:3000
BACKEND_URL=http://127.0.0.1:8000
COOKIE_SECURE=false
# Connected Apps OAuth credentials are configured by Rebly AI administrators only.
# End users never enter client IDs, secrets, redirect URIs, OAuth URLs, or scopes.
# Provider endpoint defaults are built into the backend; override with
# PROVIDER_AUTH_URI, PROVIDER_TOKEN_URI, or PROVIDER_USERINFO_URI only when needed.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
GOOGLE_CONNECTED_REDIRECT_URI=http://127.0.0.1:8000/api/connected-apps/google/callback
GOOGLE_LOGIN_WORKSPACE_SCOPES=false
GOOGLE_LOGIN_YOUTUBE_SCOPES=false
OPENROUTER_API_KEY=your-openrouter-api-key
INTEGRATION_ENCRYPTION_SECRET=replace-with-a-long-random-secret
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_TARGET_CHAT_ID=your-channel-chat-id
TELEGRAM_AUTO_PUBLISH=false
TELEGRAM_GROUP_CHAT_ID=your-public-group-or-supergroup
TELEGRAM_AGENT_API_URL=http://127.0.0.1:4173/api/agents/chat
TELEGRAM_TEAM_MESSAGE_DELAY_SECONDS=10
TELEGRAM_ATLAS_BOT_TOKEN=your-atlas-bot-token
TELEGRAM_AVA_BOT_TOKEN=your-ava-bot-token
TELEGRAM_SCOUT_BOT_TOKEN=your-scout-bot-token
